{
  "version": 2,
  "buildCommand": "flutter/bin/flutter clean && flutter/bin/flutter build web --release --base-href /",
  "outputDirectory": "build/web",
  "installCommand": "git clone https://github.com/flutter/flutter.git flutter && flutter/bin/flutter config --enable-web && flutter/bin/flutter pub get",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
